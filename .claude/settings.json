{
  "language": "chinese",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "true",
        "hooks": [
          {
            "type": "command",
            "command": "/home/zhangyangrui/my_programes/obsidian-link-tag-intelligence/.claude/hooks/session-init.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "true",
        "hooks": [
          {
            "type": "command",
            "command": "/home/zhangyangrui/my_programes/obsidian-link-tag-intelligence/.claude/hooks/session-complete.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "tool == \"Bash\" && command.startsWith(\"git commit\")",
        "hooks": [
          {
            "type": "command",
            "command": "/home/zhangyangrui/my_programes/obsidian-link-tag-intelligence/.claude/hooks/pre-commit-msg.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "OBSIDIAN_PLUGIN_DEV": "1"
  }
}
