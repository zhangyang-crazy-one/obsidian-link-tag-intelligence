            "command": "/home/zhangyangrui/my_programes/obsidian-link-tag-intelligence/.claude/hooks/pre-tool-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/zhangyangrui/my_programes/obsidian-link-tag-intelligence/.claude/hooks/session-complete.sh"
